<%- include('../partials/header', { title: 'Edit Item' }) %>

<div class="auth-wrapper">
  <div class="auth-card" style="max-width:520px;">
    <h2 class="auth-card__title">✏️ Edit Item</h2>
    <p class="auth-card__subtitle">Updates a single document — <code>updateOne</code> with <code>$set</code></p>

    <% if (error) { %>
      <div class="alert alert--error"><%= error %></div>
    <% } %>

    <form method="POST" action="/items/<%= item._id %>" class="auth-form">
      <div class="form-group">
        <label>Title *</label>
        <input type="text" name="title" value="<%= item.title %>" required />
      </div>
      <div class="form-group">
        <label>Description</label>
        <input type="text" name="description" value="<%= item.description %>" />
      </div>
      <div class="form-group">
        <label>Category</label>
        <input type="text" name="category" value="<%= item.category %>" />
      </div>
      <div class="form-group">
        <label>Author</label>
        <input type="text" name="author" value="<%= item.author %>" />
      </div>
      <button type="submit" class="btn btn--primary btn--full">Save Changes</button>
    </form>

    <p class="auth-card__footer">
      <a href="/data/<%= item._id %>">View detail</a> &nbsp;·&nbsp; <a href="/data">← Back to Data</a>
    </p>
  </div>
</div>

<%- include('../partials/footer') %>
