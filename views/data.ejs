<%- include('partials/header', { title: 'Data' }) %>

<div class="page-header">
  <div>
    <h1 class="page-header__title">📦 Items Collection</h1>
    <p class="page-header__subtitle">
      <%= items.length %> document<%= items.length !== 1 ? 's' : '' %>
      <% if (query.category || query.search) { %>
        — filtered
        <% if (query.category) { %>by category <em>"<%= query.category %>"</em><% } %>
        <% if (query.search) { %>&nbsp;· search <em>"<%= query.search %>"</em><% } %>
      <% } %>
    </p>
  </div>
  <div style="display:flex;gap:.75rem;flex-wrap:wrap;align-items:center;">
    <span class="badge badge--success">● Connected</span>
    <a href="/items/new" class="btn btn--primary btn--sm">+ Add Item</a>
    <a href="/items/bulk" class="btn btn--outline btn--sm">Bulk Insert</a>
  </div>
</div>

<%# ── Filter bar ──────────────────────────────────────────────────────────── %>
<form method="GET" action="/data" class="filter-bar" id="filterForm">
  <input
    type="text"
    name="category"
    placeholder="Filter by category (case-insensitive)"
    value="<%= query.category || '' %>"
    class="filter-input"
  />
  <input
    type="text"
    name="search"
    placeholder="Search by title or description..."
    value="<%= query.search || '' %>"
    class="filter-input"
  />
  <div class="projection-wrap">
    <input
      type="text"
      name="fields"
      id="fieldsInput"
      placeholder="Projection fields..."
      value="<%= query.fields || '' %>"
      class="filter-input"
      autocomplete="off"
    />
    <%# Hint shown below the projection input %>
    <div class="projection-hint">
      Allowed: <% allowedFields.forEach((f, i) => { %>
        <span class="projection-tag" onclick="appendField('<%= f %>')"><%= f %></span><% if (i < allowedFields.length - 1) { %>, <% } %>
      <% }) %>
    </div>
  </div>

  <%# Apply is disabled until at least one input has a value (JS handles this) %>
  <button type="submit" class="btn btn--primary btn--sm" id="applyBtn" disabled>Apply</button>
  <a href="/data" class="btn btn--outline btn--sm">Reset</a>
</form>

<%# ── Projection warning: invalid fields entered ─────────────────────────── %>
<% if (invalidFields && invalidFields.length > 0) { %>
  <div class="alert alert--warning">
    ⚠️ Unknown field<%= invalidFields.length > 1 ? 's' : '' %>
    <strong><%= invalidFields.join(', ') %></strong>
    ignored. Allowed fields: <strong><%= allowedFields.join(', ') %></strong>.
  </div>
<% } %>

<%# ── updateMany / deleteMany forms ─────────────────────────────────────────── %>
<div class="bulk-actions">
  <details class="bulk-panel">
    <summary>🔄 Update Many by Category</summary>
    <form method="POST" action="/items/update-many" class="bulk-form">
      <input type="text" name="category" placeholder="Current category (any case)" required />
      <input type="text" name="newCategory" placeholder="New category name" required />
      <button type="submit" class="btn btn--primary btn--sm">updateMany</button>
    </form>
  </details>

  <details class="bulk-panel">
    <summary>🗑️ Delete Many by Category</summary>
    <form method="POST" action="/items/delete-many" class="bulk-form"
          onsubmit="return confirm('Delete ALL items in this category?')">
      <input type="text" name="category" placeholder="Category to delete (any case)" required />
      <button type="submit" class="btn btn--sm" style="background:var(--color-danger);color:#fff;">deleteMany</button>
    </form>
  </details>
</div>

<%# ── Results ────────────────────────────────────────────────────────────── %>
<% if (items.length === 0) { %>
  <div class="empty-state">
    <div class="empty-state__icon">🔍</div>
    <% if (query.category || query.search) { %>
      <h3>No results found</h3>
      <p>
        Nothing matched
        <% if (query.category) { %> category <strong>"<%= query.category %>"</strong><% } %>
        <% if (query.search) { %> search <strong>"<%= query.search %>"</strong><% } %>.
        <br/>Try different keywords or <a href="/data">view all items</a>.
      </p>
    <% } else { %>
      <h3>Collection is empty</h3>
      <p><a href="/items/new">Add your first item</a> or use <a href="/items/bulk">Bulk Insert</a>.</p>
    <% } %>
  </div>
<% } else { %>
  <div class="data-grid">
    <% items.forEach(item => { %>
      <div class="data-card">
        <div class="data-card__header">
          <span class="data-card__category"><%= item.category || '—' %></span>
          <span class="data-card__date">
            <%= item.createdAt ? new Date(item.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) : '' %>
          </span>
        </div>
        <h3 class="data-card__title"><%= item.title || '—' %></h3>
        <p class="data-card__description"><%= item.description || 'No description.' %></p>
        <div class="data-card__footer">
          <span class="data-card__author">✍️ <%= item.author || '—' %></span>
          <div style="display:flex;gap:.5rem;">
            <% if (item._id) { %>
              <a href="/items/<%= item._id %>/edit" class="btn btn--outline btn--sm">Edit</a>
              <form method="POST" action="/items/<%= item._id %>/delete"
                    onsubmit="return confirm('Delete this item?')" style="display:inline;">
                <button type="submit" class="btn btn--sm" style="background:var(--color-danger);color:#fff;">Del</button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<script>
  // ── Enable Apply button only when at least one filter input has a value ──
  const form     = document.getElementById('filterForm');
  const applyBtn = document.getElementById('applyBtn');
  const inputs   = form.querySelectorAll('input[type="text"]');

  function checkInputs() {
    const hasValue = [...inputs].some(i => i.value.trim() !== '');
    applyBtn.disabled = !hasValue;
  }

  inputs.forEach(i => i.addEventListener('input', checkInputs));

  // Run on page load so the button is enabled if URL already has params
  checkInputs();

  // ── Click a projection tag to append it to the fields input ──────────────
  function appendField(field) {
    const input = document.getElementById('fieldsInput');
    const current = input.value.trim();
    const fields = current ? current.split(',').map(f => f.trim()).filter(Boolean) : [];
    if (!fields.includes(field)) {
      fields.push(field);
      input.value = fields.join(',');
    }
    checkInputs();
    input.focus();
  }
</script>

<%- include('partials/footer') %>
