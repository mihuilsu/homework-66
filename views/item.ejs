<%- include('partials/header', { title: item.title }) %>

<div class="page-header">
  <a href="/data" class="btn btn--outline btn--sm">← Back to Data</a>
  <div style="display:flex;gap:.75rem;">
    <a href="/items/<%= item._id %>/edit" class="btn btn--primary btn--sm">✏️ Edit (updateOne)</a>
  </div>
</div>

<div class="item-detail">
  <div class="item-detail__meta">
    <span class="badge badge--category"><%= item.category %></span>
    <span class="item-detail__date">
      <%= new Date(item.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' }) %>
    </span>
  </div>

  <h1 class="item-detail__title"><%= item.title %></h1>
  <p class="item-detail__description"><%= item.description || 'No description provided.' %></p>

  <div class="item-detail__footer">
    <span>✍️ <strong><%= item.author %></strong></span>
    <span class="item-detail__id">MongoDB ID: <code><%= item._id %></code></span>
  </div>
</div>

<%# ── replaceOne form ────────────────────────────────────────────────────────── %>
<div class="item-detail" style="margin-top:1.5rem;">
  <h3 style="margin-bottom:1rem;font-size:1rem;color:var(--color-text-muted);">
    🔁 replaceOne — fully replace this document
  </h3>
  <form method="POST" action="/items/<%= item._id %>/replace" class="auth-form">
    <div class="form-group">
      <label>Title</label>
      <input type="text" name="title" value="<%= item.title %>" required />
    </div>
    <div class="form-group">
      <label>Description</label>
      <input type="text" name="description" value="<%= item.description %>" />
    </div>
    <div class="form-group">
      <label>Category</label>
      <input type="text" name="category" value="<%= item.category %>" />
    </div>
    <div class="form-group">
      <label>Author</label>
      <input type="text" name="author" value="<%= item.author %>" />
    </div>
    <button type="submit" class="btn btn--outline">Replace Document</button>
  </form>
</div>

<%- include('partials/footer') %>
